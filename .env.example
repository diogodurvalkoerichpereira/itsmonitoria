# ---------------------------------------------------------------------------
# iTS Qualidade — variaveis de ambiente
# Copie para .env e ajuste os valores. NUNCA versione o .env real.
# ---------------------------------------------------------------------------

# Ambiente: "production" ativa cookies secure, HSTS, trust proxy e desliga
# os dados/usuarios de demonstracao.
NODE_ENV=production

# Porta HTTP do servidor. Em PaaS (Hostinger Web app Node.js) e injetada
# automaticamente — nao defina.
PORT=3000

# --- Banco de dados (PostgreSQL) ---------------------------------------------
# String de conexao do Postgres. OBRIGATORIA. Ex.: Supabase (use o pooler):
# DATABASE_URL=postgresql://postgres.<ref>:<senha>@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
# Postgres local de desenvolvimento:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/its_qualidade
DATABASE_URL=

# Desliga SSL na conexao (use apenas em Postgres local). Em provedores
# gerenciados (Supabase) deixe vazio — o SSL e habilitado automaticamente.
PGSSL=

# Segredo de assinatura dos tokens JWT.
# OBRIGATORIO em producao, minimo 32 caracteres aleatorios.
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Administrador inicial criado no primeiro start em producao
# (apenas se o banco ainda nao tiver nenhum usuario).
ADMIN_NOME=Administrador
ADMIN_EMAIL=admin@suaempresa.com.br
ADMIN_PASSWORD=

# Defina como "true" para popular o banco com dados ficticios de demonstracao
# mesmo em producao. Mantenha vazio/false em ambientes reais.
SEED_DEMO=

# Diretorio persistente para o banco SQLite e os uploads.
# IMPORTANTE em hospedagens que reconstroem a pasta do app a cada deploy
# (ex.: Hostinger via GitHub): aponte para um caminho FORA do projeto que
# sobreviva aos redeploys, senao os dados sao perdidos a cada publicacao.
# Ex.: DATA_DIR=/home/SEU_USUARIO/its-qualidade-data
# Se vazio, usa a pasta ./data dentro do projeto (ideal para desenvolvimento).
DATA_DIR=
