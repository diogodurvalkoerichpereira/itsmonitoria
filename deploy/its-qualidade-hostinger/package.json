{
  "name": "its-qualidade",
  "version": "1.0.0",
  "description": "ITSCS - Modulo de Qualidade (monitoria de atendimento, dashboard, calibracao e contestacoes)",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch src/server.ts",
    "dev:client": "vite",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.json",
    "start": "node --no-warnings dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=22 <25"
  },
  "dependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.20.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "pg": "^8.22.0",
    "typescript": "^5.7.3",
    "vite": "^8.1.0"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "tsx": "^4.19.2"
  }
}
