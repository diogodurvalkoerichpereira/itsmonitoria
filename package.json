{
  "name": "its-qualidade",
  "version": "1.0.0",
  "description": "ITSCS - Modulo de Qualidade (monitoria de atendimento, dashboard, calibracao e contestacoes)",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --experimental-sqlite src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --no-warnings --experimental-sqlite dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=22 <25"
  },
  "dependencies": {
    "@types/multer": "^2.1.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
